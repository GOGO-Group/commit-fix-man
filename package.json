{
  "name": "commit-maker",
  "version": "1.0.0",
  "description": "View and manage commit calendars across multiple repositories",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.commit-maker.app",
    "productName": "Commit Maker",
    "win": {
      "target": "nsis",
      "icon": "static/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": [
      "main.js",
      "preload.js",
      "pages/**/*",
      "styles/**/*",
      "static/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  }
}
